# Field Service CRM / A3 Platform
# Copy this file to .env for local development.
# Never put real production secrets into git.

# Runtime mode
ENV=development
COOKIE_SECURE=0

# Required in production.
# Generate a long random value before deploy.
SECRET_KEY=replace-with-long-random-secret

# Local data directory.
# Railway can keep the default or point this to a mounted volume.
DATA_DIR=.

# Telegram notifications.
# Leave empty locally if Telegram is not needed.
BOT_TOKEN=
CHAT_ID=

# Secret for protected automation cron endpoints.
# Use a long random value in production.
AUTOMATION_CRON_SECRET=replace-with-long-random-cron-secret

# Railway sets these automatically. Do not set manually unless needed.
# RAILWAY_ENVIRONMENT=
# RAILWAY_ENVIRONMENT_NAME=
# RAILWAY_GIT_COMMIT_SHA=
# RAILWAY_GIT_BRANCH=
# RAILWAY_DEPLOYMENT_ID=
# RAILWAY_SERVICE_NAME=
